# Copy this file to .env and fill in your credentials
# NEVER commit .env file to git

# SMTP (Gmail)
# Get App Password from: https://myaccount.google.com/apppasswords (2FA must be enabled)
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
WARDEN_EMAIL=warden@example.com

# Twilio SMS (Optional)
# Get credentials from: https://www.twilio.com/console
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_FROM=+1234567890
WARDEN_PHONE=+911234567890
SMS_GATEWAY_DOMAIN=  # Leave empty if using Twilio
